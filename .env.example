# frit -- single GCP-VM GPU lab. Copy to .env (gitignored) and fill in.
# No secrets in git: gcloud creds live in ~/.config/gcloud, the SSH key in ~/.ssh.
# The external IP is resolved live from gcloud each run, so it is never hardcoded.

# -- The GPU VM (GCP) ----------------------------------------------------------
# The VM MUST have an NVIDIA GPU attached (e.g. --accelerator nvidia-tesla-t4).
# Confirm with: gcloud compute instances describe <name> --format="value(guestAccelerators)"
GCP_PROJECT=                       # your GCP project id
GCP_ZONE=                          # a GCP zone with GPU availability
GCP_VM_NAME=                       # your GPU VM name
TARGET_USER=                       # ssh user on the VM
SSH_KEY_PATH=~/.ssh/id_ed25519     # private key for that user

# Not a GCP VM? Leave GCP_* blank and point at any GPU host instead:
#   TARGET_HOST=<ssh-config-alias|ip>   (+ optional TARGET_PORT / SSH_JUMP)
TARGET_HOST=
TARGET_PORT=
SSH_JUMP=
BECOME_PASS=                       # only if the user needs a sudo password

# -- Gitea (in-cluster Git) ----------------------------------------------------
GITEA_NODEPORT=30080
GITEA_ADMIN_USER=gitea-admin
GITEA_ADMIN_PASSWORD=change-me-gitea
GITEA_ADMIN_EMAIL=admin@frit.local

# -- Vault (left empty -- bootstrap fills these after the first cluster up) -----
VAULT_UNSEAL_KEY=
VAULT_ROOT_TOKEN=

# -- HuggingFace (required for gated models) -----------------------------------
HF_TOKEN=hf_your-token-here

# -- Model ---------------------------------------------------------------------
MODEL_NAME=meta-llama/Meta-Llama-3-8B-Instruct

# -- Grafana -------------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-grafana

# -- Langfuse ------------------------------------------------------------------
LANGFUSE_SECRET_KEY=change-me-langfuse-secret
LANGFUSE_SALT=change-me-langfuse-salt
LANGFUSE_POSTGRES_PASSWORD=change-me-langfuse-db
