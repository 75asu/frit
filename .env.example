# Copy to .env and fill in your values.
# .env is gitignored — never commit it.
# bootstrap.yaml reads these via the shell environment (Makefile exports them).
#
# How to find these values:
#   LIGHTNING_API_KEY + LIGHTNING_USER_ID — Lightning.ai profile → Keys → API key
#   STUDIO_TEAMSPACE  — the teamspace name shown in your Lightning.ai URL
#   STUDIO_USER       — your Lightning.ai username
#   HF_TOKEN          — huggingface.co/settings/tokens (needs read access to gated models)

# -- Lightning.ai studio -------------------------------------------------------
LIGHTNING_API_KEY=your-api-key
LIGHTNING_USER_ID=your-user-id

STUDIO_NAME=frit
STUDIO_TEAMSPACE=your-teamspace-name
STUDIO_USER=your-lightning-username
STUDIO_DIR=/teamspace/studios/this_studio
STUDIO_MACHINE=T4

# -- Gitea (in-cluster Git) ----------------------------------------------------
GITEA_NODEPORT=30080
GITEA_ADMIN_USER=gitea-admin
GITEA_ADMIN_PASSWORD=change-me-gitea
GITEA_ADMIN_EMAIL=admin@frit.local

# -- Vault ---------------------------------------------------------------------
# Left empty — filled in automatically by bootstrap.yaml after first `make up`.
# If you re-run bootstrap.yaml on an already-initialized Vault, set these manually.
VAULT_UNSEAL_KEY=
VAULT_ROOT_TOKEN=

# -- HuggingFace ---------------------------------------------------------------
# Required for gated models (Llama-3, Mistral). Get a token at hf.co/settings/tokens.
HF_TOKEN=hf_your-token-here

# -- Model selection -----------------------------------------------------------
# Change model here and re-run make bootstrap to update the Vault secret.
# The vLLM HelmRelease in deploy/k8s/apps/vllm/helmrelease.yaml must also be updated.
MODEL_NAME=meta-llama/Meta-Llama-3-8B-Instruct

# -- Grafana -------------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-grafana

# -- Langfuse (M5) -------------------------------------------------------------
LANGFUSE_SECRET_KEY=change-me-langfuse-secret
LANGFUSE_SALT=change-me-langfuse-salt
LANGFUSE_POSTGRES_PASSWORD=change-me-langfuse-db
